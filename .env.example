# Core server settings
PORT=4321
NODE_ENV=development
BASE_URL=http://localhost:4321
TRUST_PROXY=false

# AI providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENAI_CODEX_CLIENT_ID=

# Optional web search providers
TAVILY_API_KEY=
SERPER_API_KEY=
BRAVE_API_KEY=
SEARCH_ENGINE=duckduckgo

# Storage
DATABASE_URL=postgresql://shortcut_genius:shortcut_genius@localhost:5432/shortcut_genius
# Set one of these to avoid Postgres locally
# CONVERSATION_STORE_MODE=memory
# NO_STORAGE_MODE=true

# Optional local data dir for provider state and generated reports
# SHORTCUT_GENIUS_DATA_DIR=.local/shortcut-genius
